GITHUB_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REPOGUARDIAN_MODEL=gpt-4.1-mini
REPOGUARDIAN_PROVIDER=openai
REPOGUARDIAN_GIT_BIN=git

# Product defaults: read-only review never runs repository code.
REPOGUARDIAN_DEFAULT_REVIEW_MODE=review
REPOGUARDIAN_DEFAULT_VALIDATION_BACKEND=none

# Deterministic Review Unit planning and bounded execution.
REPOGUARDIAN_REVIEW_UNIT_CONCURRENCY=4
REPOGUARDIAN_REVIEW_UNIT_TIMEOUT_SECONDS=180
REPOGUARDIAN_REVIEW_UNIT_SMALL_MAX_CHANGED_LINES=30
REPOGUARDIAN_REVIEW_UNIT_LARGE_MIN_CHANGED_LINES=400
REPOGUARDIAN_REVIEW_UNIT_MAX_LINES_PER_READ=240
REPOGUARDIAN_REVIEW_UNIT_MAX_SEARCH_RESULTS=12

# Command execution defaults to a rejecting sandbox placeholder. A real sandbox runtime
# must be configured before production validation can execute untrusted repository code.
# reject is the safe default; gvisor remains a non-executing placeholder.
REPOGUARDIAN_EXECUTOR=reject
REPOGUARDIAN_ALLOW_UNSAFE_LOCAL_EXECUTION=false
REPOGUARDIAN_SANDBOX_NETWORK=false
REPOGUARDIAN_SANDBOX_MEMORY_MB=512
REPOGUARDIAN_SANDBOX_CPUS=1.0
REPOGUARDIAN_SANDBOX_PIDS_LIMIT=64
REPOGUARDIAN_SANDBOX_TIMEOUT_SECONDS=300
REPOGUARDIAN_SANDBOX_MAX_OUTPUT_CHARS=8000

# LangSmith tracing is opt-in. Leave false to prevent all LangSmith requests.
REPOGUARDIAN_LANGSMITH_TRACING=false
# Required only when tracing is enabled. Never commit a real key.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=repoguardian
# Optional custom endpoint, for example a self-hosted LangSmith deployment.
# LANGSMITH_ENDPOINT=
# false keeps trace structure and safe metadata only; no prompts, diffs, context, or model output.
REPOGUARDIAN_LANGSMITH_INCLUDE_CONTENT=false

# 以下路径默认相对于 backend/ 目录，可覆盖为自定义路径
# REPOGUARDIAN_WORKDIR=backend/.repoguardian/workspaces
# REPOGUARDIAN_DB_PATH=backend/.repoguardian/repoguardian.db
# REPOGUARDIAN_CHECKPOINT_DB=backend/.repoguardian/checkpoints.db

# DeepSeek example:
# OPENAI_BASE_URL=https://api.deepseek.com
# REPOGUARDIAN_MODEL=deepseek-v4-pro
# REPOGUARDIAN_PROVIDER=deepseek
