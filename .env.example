GITHUB_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REPOGUARDIAN_MODEL=gpt-4.1-mini
REPOGUARDIAN_PROVIDER=mock
REPOGUARDIAN_GIT_BIN=git
# 以下路径默认相对于 backend/ 目录，可覆盖为自定义路径
# REPOGUARDIAN_WORKDIR=backend/.repoguardian/workspaces
# REPOGUARDIAN_DB_PATH=backend/.repoguardian/repoguardian.db
# REPOGUARDIAN_CHECKPOINT_DB=backend/.repoguardian/checkpoints.db

# DeepSeek example:
# OPENAI_BASE_URL=https://api.deepseek.com
# REPOGUARDIAN_MODEL=deepseek-v4-pro
# REPOGUARDIAN_PROVIDER=deepseek